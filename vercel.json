{
    "version": 2,
    "builds": [
        {
            "src": "mobile-store/backend/main.py",
            "use": "@vercel/python"
        },
        {
            "src": "mobile-store/frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "mobile-store/backend/main.py"
        },
        {
            "src": "/(.*)",
            "dest": "mobile-store/frontend/$1",
            "check": true
        }
    ]
}